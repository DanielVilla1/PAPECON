# ── PAPECON Backend Environment Variables ─────────────
# Copy this file to .env and fill in real values.

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/papecon

# JWT secret — generate a strong random string for production
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME

# Frontend URL (used in verification email links)
FRONTEND_URL=https://your-frontend-domain.com

# ── Gmail SMTP (for sending verification emails) ───
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
